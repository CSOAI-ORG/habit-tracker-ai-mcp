{
  "name": "habit-tracker-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Track habits, streaks, and build accountability.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "create_habit",
      "description": "Create new habit",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          },
          "reminder_time": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "name": "log_completion",
      "description": "Log habit completion",
      "parameters": {
        "type": "object",
        "properties": {
          "habit_id": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "habit_id"
        ]
      }
    },
    {
      "name": "get_habit_streak",
      "description": "Get current streak",
      "parameters": {
        "type": "object",
        "properties": {
          "habit_id": {
            "type": "string"
          }
        },
        "required": [
          "habit_id"
        ]
      }
    },
    {
      "name": "get_habit_history",
      "description": "Get habit history",
      "parameters": {
        "type": "object",
        "properties": {
          "habit_id": {
            "type": "string"
          },
          "days": {
            "type": "integer"
          }
        },
        "required": [
          "habit_id"
        ]
      }
    },
    {
      "name": "get_all_habits",
      "description": "Get all habits",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "delete_habit",
      "description": "Delete habit",
      "parameters": {
        "type": "object",
        "properties": {
          "habit_id": {
            "type": "string"
          }
        },
        "required": [
          "habit_id"
        ]
      }
    },
    {
      "name": "get_weekly_stats",
      "description": "Get weekly stats",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  ]
